---
import Layout from '../layouts/Layout.astro';
const baseRaw = import.meta.env.BASE_URL;
const base = baseRaw.endsWith('/') ? baseRaw : baseRaw + '/';
---

<Layout title="Home" description="AutoLeaf Displays - Professionele digitale menukaarten voor coffeeshops. Real-time prijslijsten op grote schermen, mobiele app voor productinfo, en kassa-integraties.">
  
  <!-- Hero Section -->
  <section class="hero min-h-[85vh] flex items-start lg:pt-20 relative">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-leaf-light font-medium tracking-wider uppercase mb-4 text-sm">Voor professionele coffeeshops</p>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
            Digitale menukaarten die <span class="text-leaf-light">meedenken</span>
          </h1>
          <p class="text-xl text-white/80 mb-8 leading-relaxed">
            AutoLeaf is het complete display-systeem voor coffeeshops in de wietproef. 
            Real-time prijslijsten op grote schermen, automatische voorraad-updates, 
            en een mobiele app voor uitgebreide productinformatie.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href={`${base}contact/`} class="btn-primary text-center">
              Gratis demo aanvragen →
            </a>
            <a href={`${base}functies/`} class="btn-secondary text-center">
              Bekijk functies
            </a>
          </div>
        </div>
        <div>
          <p class="text-center text-white/50 text-sm mb-4 tracking-wider uppercase" id="carousel-title" style="transition: opacity 0.2s ease;">Menukaart Display</p>
          
          <!-- Carousel with external arrows -->
          <div class="flex items-center gap-3">
            <!-- Prev arrow -->
            <button class="flex-shrink-0 bg-white/10 hover:bg-white/20 text-white w-10 h-10 rounded-full flex items-center justify-center transition-all" id="carousel-prev">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </button>
            
            <!-- Track -->
            <div class="overflow-hidden rounded-xl flex-grow">
              <div class="carousel-track flex transition-transform duration-500 ease-in-out" id="carousel-track">
                <div class="carousel-slide w-full flex-shrink-0 px-2">
                  <img src={`${base}screenshots/slide-1.jpg`} alt="AutoLeaf menukaart display" class="rounded-xl shadow-lg w-full" />
                </div>
                <div class="carousel-slide w-full flex-shrink-0 px-2">
                  <img src={`${base}screenshots/slide-2.jpg`} alt="Coffeeshop Mississippi menukaart" class="rounded-xl shadow-lg w-full" />
                </div>
                <div class="carousel-slide w-full flex-shrink-0 px-2">
                  <img src={`${base}screenshots/slide-3.jpg`} alt="AutoLeaf admin dashboard" class="rounded-xl shadow-lg w-full" />
                </div>
                <div class="carousel-slide w-full flex-shrink-0 px-2">
                  <img src={`${base}screenshots/slide-4.jpg`} alt="Kiosk Mode" class="rounded-xl shadow-lg w-full" />
                </div>
                <div class="carousel-slide w-full flex-shrink-0 px-2">
                  <img src={`${base}screenshots/slide-5.jpg`} alt="Product detail pagina" class="rounded-xl shadow-lg w-full" />
                </div>
                <div class="carousel-slide w-full flex-shrink-0 px-2">
                  <img src={`${base}screenshots/slide-6.jpg`} alt="Coffeeshop partners" class="rounded-xl shadow-lg w-full" />
                </div>
              </div>
            </div>
            
            <!-- Next arrow -->
            <button class="flex-shrink-0 bg-white/10 hover:bg-white/20 text-white w-10 h-10 rounded-full flex items-center justify-center transition-all" id="carousel-next">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
          
          <!-- Dots -->
          <div class="flex justify-center gap-2 mt-5" id="carousel-dots">
            <button class="w-2.5 h-2.5 rounded-full bg-white/80 transition-all carousel-dot" data-index="0"></button>
            <button class="w-2.5 h-2.5 rounded-full bg-white/30 hover:bg-white/50 transition-all carousel-dot" data-index="1"></button>
            <button class="w-2.5 h-2.5 rounded-full bg-white/30 hover:bg-white/50 transition-all carousel-dot" data-index="2"></button>
            <button class="w-2.5 h-2.5 rounded-full bg-white/30 hover:bg-white/50 transition-all carousel-dot" data-index="3"></button>
            <button class="w-2.5 h-2.5 rounded-full bg-white/30 hover:bg-white/50 transition-all carousel-dot" data-index="4"></button>
            <button class="w-2.5 h-2.5 rounded-full bg-white/30 hover:bg-white/50 transition-all carousel-dot" data-index="5"></button>
          </div>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <!-- Stats -->
  <section class="py-16 -mt-12 relative z-10">
    <div class="max-w-5xl mx-auto px-6">
      <div class="bg-white rounded-2xl shadow-xl p-8 grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="stat-item">
          <p class="stat-number">100+</p>
          <p class="text-gray-600 text-sm mt-2">Soorten support</p>
        </div>
        <div class="stat-item">
          <p class="stat-number">2</p>
          <p class="text-gray-600 text-sm mt-2">Kassa integraties</p>
        </div>
        <div class="stat-item">
          <p class="stat-number">24/7</p>
          <p class="text-gray-600 text-sm mt-2">Live updates</p>
        </div>
        <div class="stat-item">
          <p class="stat-number">NL</p>
          <p class="text-gray-600 text-sm mt-2">Wietproef ready</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Overview -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Alles voor uw digitale menukaart</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Van real-time prijsweergave tot klantgerichte productinformatie — AutoLeaf heeft alles in huis.
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="feature-card">
          <div class="text-5xl mb-6">📺</div>
          <h3 class="text-xl font-bold mb-3 text-forest">Display Systeem</h3>
          <p class="text-gray-600">
            Projecteer uw volledige assortiment op grote schermen. Uitverkochte producten verdwijnen automatisch.
          </p>
        </div>
        <div class="feature-card">
          <div class="text-5xl mb-6">📱</div>
          <h3 class="text-xl font-bold mb-3 text-forest">Mobiele App</h3>
          <p class="text-gray-600">
            Geef klanten uitgebreide productinfo via hun smartphone. Effecten, smaken, herkomst en meer.
          </p>
        </div>
        <div class="feature-card">
          <div class="text-5xl mb-6">🔗</div>
          <h3 class="text-xl font-bold mb-3 text-forest">Kassa Integratie</h3>
          <p class="text-gray-600">
            Naadloze koppeling met EBPos en Vectron Commander. Voorraad altijd up-to-date.
          </p>
        </div>
      </div>
      
      <div class="text-center mt-12">
        <a href={`${base}functies/`} class="btn-outline">
          Alle functies bekijken →
        </a>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section-cream py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Hoe werkt het?</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          In drie stappen van powerpoint naar professionele digitale menukaarten die in sync zijn met de voorraad.
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-leaf text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">1</div>
          <h3 class="text-xl font-bold mb-3">Koppel uw kassa</h3>
          <p class="text-gray-600">
            Wij verbinden AutoLeaf met uw bestaande kassasysteem. Geen dubbel werk meer.
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-leaf text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">2</div>
          <h3 class="text-xl font-bold mb-3">Configureer displays</h3>
          <p class="text-gray-600">
            Bepaal welke producten op welk scherm. Pas kleuren en layout aan uw huisstijl aan.
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-leaf text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">3</div>
          <h3 class="text-xl font-bold mb-3">Ga live</h3>
          <p class="text-gray-600">
            Uw menukaart draait. Verkochte producten verdwijnen automatisch. Klanten gebruiken de app.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Integrations -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Kassa Integraties</h2>
        <p class="text-lg text-gray-600">
          Werkt naadloos met de meest gebruikte kassasystemen in de branche.
        </p>
      </div>
      
      <div class="flex flex-wrap justify-center items-center gap-12">
        <div class="text-center p-8 rounded-xl border border-gray-200 hover:border-leaf transition-colors">
          <div class="text-4xl mb-3">💳</div>
          <p class="font-bold text-lg">EBPos</p>
          <p class="text-gray-500 text-sm">Volledige integratie</p>
        </div>
        <div class="text-center p-8 rounded-xl border border-gray-200 hover:border-leaf transition-colors">
          <div class="text-4xl mb-3">🖥️</div>
          <p class="font-bold text-lg">Vectron Commander</p>
          <p class="text-gray-500 text-sm">Volledige integratie</p>
        </div>
      </div>
      
      <div class="text-center mt-8">
        <p class="text-gray-500">Ander kassasysteem? <a href={`${base}contact/`} class="text-leaf font-semibold hover:underline">Neem contact op</a></p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-forest py-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-6">Klaar voor professionele displays?</h2>
      <p class="text-xl text-white/80 mb-8">
        Plan een gratis demo en ontdek hoe AutoLeaf uw coffeeshop naar een hoger niveau tilt.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}contact/`} class="btn-primary bg-white !text-forest hover:!bg-white/90">
          Gratis demo aanvragen
        </a>
        <a href="tel:+31495794123" class="btn-secondary">
          Bel ons direct
        </a>
      </div>
    </div>
  </section>

</Layout>

<script>
  const track = document.getElementById('carousel-track');
  const dots = document.querySelectorAll('.carousel-dot');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');
  const titleEl = document.getElementById('carousel-title');
  let current = 0;
  const total = 6;
  let autoplayTimer;

  const titles = [
    'Menukaart Display',
    'Coffeeshop Menukaart',
    'Admin Dashboard',
    'Kiosk Mode',
    'Product Detail',
    'Onze Partners',
  ];

  function goTo(index) {
    current = ((index % total) + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => {
      d.classList.toggle('bg-white/80', i === current);
      d.classList.toggle('bg-white/30', i !== current);
    });
    if (titleEl) {
      titleEl.style.opacity = '0';
      setTimeout(() => { titleEl.textContent = titles[current]; titleEl.style.opacity = '1'; }, 200);
    }
  }

  function startAutoplay() {
    autoplayTimer = setInterval(() => goTo(current + 1), 5000);
  }
  function resetAutoplay() {
    clearInterval(autoplayTimer);
    startAutoplay();
  }

  prevBtn?.addEventListener('click', () => { goTo(current - 1); resetAutoplay(); });
  nextBtn?.addEventListener('click', () => { goTo(current + 1); resetAutoplay(); });
  dots.forEach(d => d.addEventListener('click', () => { goTo(parseInt(d.dataset.index)); resetAutoplay(); }));

  // Touch/swipe support
  let startX = 0;
  let isDragging = false;
  track?.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; isDragging = true; }, { passive: true });
  track?.addEventListener('touchend', (e) => {
    if (!isDragging) return;
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) {
      goTo(diff > 0 ? current + 1 : current - 1);
      resetAutoplay();
    }
    isDragging = false;
  });

  startAutoplay();
</script>
