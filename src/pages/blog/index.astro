---
import Layout from '../../layouts/Layout.astro';
const baseRaw = import.meta.env.BASE_URL;
const base = baseRaw.endsWith('/') ? baseRaw : baseRaw + '/';

// Get all blog posts using import.meta.glob
const postFiles = import.meta.glob('./*.md', { eager: true });
const posts = Object.values(postFiles) as any[];
const sortedPosts = posts.sort((a, b) => 
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---

<Layout title="Blog" description="Nieuws en inzichten over de Nederlandse wietproef, coffeeshop technologie en AutoLeaf updates.">
  
  <!-- Hero -->
  <section class="hero py-16">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">
          <span class="text-leaf-light">Blog</span>
        </h1>
        <p class="text-xl text-white/80">
          Nieuws over de wietproef, cannabis industrie en digitale innovatie voor coffeeshops.
        </p>
      </div>
    </div>
  </section>

  <!-- Blog Posts -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedPosts.map((post) => (
          <a href={post.url} class="blog-card group">
            <div class="p-6">
              <div class="flex items-center gap-3 text-sm text-gray-500 mb-3">
                <time datetime={post.frontmatter.date}>
                  {new Date(post.frontmatter.date).toLocaleDateString('nl-NL', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
                {post.frontmatter.tags && (
                  <>
                    <span>•</span>
                    <span class="text-leaf">{post.frontmatter.tags[0]}</span>
                  </>
                )}
              </div>
              <h2 class="text-xl font-bold mb-3 group-hover:text-leaf transition-colors">
                {post.frontmatter.title}
              </h2>
              <p class="text-gray-600 line-clamp-3">
                {post.frontmatter.description}
              </p>
              <span class="inline-block mt-4 text-leaf font-semibold text-sm">
                Lees meer →
              </span>
            </div>
          </a>
        ))}
      </div>

      {sortedPosts.length === 0 && (
        <div class="text-center py-12">
          <p class="text-gray-500">Nog geen blogposts. Kom snel terug!</p>
        </div>
      )}
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="section-cream py-16">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-2xl font-bold mb-4">Blijf op de hoogte</h2>
      <p class="text-gray-600 mb-6">
        Maandelijks nieuws over de wietproef en coffeeshop innovatie in je inbox.
      </p>
      <form action="https://formspree.io/f/xpwrqdkz" method="POST" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input type="hidden" name="_subject" value="Nieuwe nieuwsbrief aanmelding - AutoLeaf" />
        <input type="email" name="email" placeholder="Je e-mailadres" required
          class="flex-1 px-4 py-3 rounded-lg border border-gray-300 focus:border-leaf focus:ring-2 focus:ring-leaf/20 outline-none">
        <button type="submit" class="btn-primary whitespace-nowrap">Aanmelden</button>
      </form>
    </div>
  </section>

</Layout>
