---
import Layout from '../layouts/Layout.astro';
const baseRaw = import.meta.env.BASE_URL;
const base = baseRaw.endsWith('/') ? baseRaw : baseRaw + '/';
---

<Layout title="Functies" description="Ontdek alle functies van AutoLeaf Displays - digitale menukaarten, mobiele app, real-time voorraad en kassa-integraties voor coffeeshops.">
  
  <!-- Hero -->
  <section class="hero py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">
          Alle functies voor de <span class="text-leaf-light">moderne coffeeshop</span>
        </h1>
        <p class="text-xl text-white/80">
          Van digitale displays tot mobiele klantapps — AutoLeaf biedt alles wat u nodig heeft.
        </p>
      </div>
    </div>
  </section>

  <!-- Display System -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-leaf font-semibold text-sm uppercase tracking-wider">Display Systeem</span>
          <h2 class="text-3xl sm:text-4xl font-bold mt-2 mb-6">Prijslijsten op groot formaat</h2>
          <p class="text-gray-600 mb-6 text-lg">
            Projecteer uw complete assortiment op professionele displays. Perfect voor coffeeshops met 100+ soorten.
          </p>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="text-leaf text-xl">✓</span>
              <span><strong>Auto-hide bij uitverkocht</strong> — Producten verdwijnen zodra de voorraad op is</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-leaf text-xl">✓</span>
              <span><strong>Meerdere schermen</strong> — Verschillende categorieën per display</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-leaf text-xl">✓</span>
              <span><strong>Aanpasbare layout</strong> — Kleuren en fonts naar uw huisstijl</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-leaf text-xl">✓</span>
              <span><strong>THC/CBD percentages</strong> — Wettelijk verplichte info altijd zichtbaar</span>
            </li>
          </ul>
        </div>
        <div class="bg-forest rounded-2xl p-8">
          <div class="space-y-3">
            <div class="bg-white/10 rounded-lg p-4">
              <div class="flex justify-between items-center">
                <div>
                  <p class="text-white font-semibold">Super Silver Haze</p>
                  <p class="text-white/60 text-sm">Sativa · THC 21% · CBD 0.1%</p>
                </div>
                <p class="text-leaf-light font-bold text-xl">€13,00</p>
              </div>
            </div>
            <div class="bg-white/10 rounded-lg p-4">
              <div class="flex justify-between items-center">
                <div>
                  <p class="text-white font-semibold">OG Kush</p>
                  <p class="text-white/60 text-sm">Hybrid · THC 19% · CBD 0.3%</p>
                </div>
                <p class="text-leaf-light font-bold text-xl">€12,00</p>
              </div>
            </div>
            <div class="bg-white/10 rounded-lg p-4">
              <div class="flex justify-between items-center">
                <div>
                  <p class="text-white font-semibold">Blue Dream</p>
                  <p class="text-white/60 text-sm">Hybrid · THC 20% · CBD 0.2%</p>
                </div>
                <p class="text-leaf-light font-bold text-xl">€11,50</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mobile App -->
  <section class="section-cream py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1">
          <div class="bg-white rounded-3xl shadow-xl p-6 max-w-xs mx-auto">
            <div class="bg-gray-100 rounded-2xl p-4">
              <div class="text-center mb-4">
                <span class="text-4xl">🌿</span>
                <h4 class="font-bold mt-2">Amnesia Haze</h4>
                <p class="text-sm text-gray-500">Sativa Dominant</p>
              </div>
              <div class="space-y-3 text-sm">
                <div class="flex justify-between">
                  <span class="text-gray-500">THC</span>
                  <span class="font-semibold">22%</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-gray-500">CBD</span>
                  <span class="font-semibold">0.1%</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-gray-500">Herkomst</span>
                  <span class="font-semibold">Nederland</span>
                </div>
                <div class="pt-3 border-t">
                  <p class="text-gray-600 text-xs">Effecten: Energiek, creatief, euforisch. Ideaal voor overdag.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <span class="text-leaf font-semibold text-sm uppercase tracking-wider">Mobiele App</span>
          <h2 class="text-3xl sm:text-4xl font-bold mt-2 mb-6">Productinfo in de hand van uw klant</h2>
          <p class="text-gray-600 mb-6 text-lg">
            Klanten scannen een QR-code en krijgen direct toegang tot uitgebreide productinformatie.
          </p>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="text-leaf text-xl">✓</span>
              <span><strong>Gedetailleerde info</strong> — THC/CBD, terpenen, effecten, smaken</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-leaf text-xl">✓</span>
              <span><strong>Geen app download nodig</strong> — Werkt direct in de browser</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-leaf text-xl">✓</span>
              <span><strong>Meertalig</strong> — Nederlands, Engels, Duits, Frans</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-leaf text-xl">✓</span>
              <span><strong>Uw branding</strong> — Volledig in uw huisstijl</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Real-time sync -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-leaf font-semibold text-sm uppercase tracking-wider">Real-time Synchronisatie</span>
        <h2 class="text-3xl sm:text-4xl font-bold mt-2 mb-4">Altijd actuele informatie</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Zodra u een verkoop registreert in uw kassa, wordt de voorraad overal bijgewerkt.
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="feature-card">
          <div class="text-5xl mb-6">⚡</div>
          <h3 class="text-xl font-bold mb-3 text-forest">Instant Updates</h3>
          <p class="text-gray-600">
            Wijzigingen verschijnen binnen seconden op alle displays en in de mobiele app.
          </p>
        </div>
        <div class="feature-card">
          <div class="text-5xl mb-6">🔄</div>
          <h3 class="text-xl font-bold mb-3 text-forest">Automatisch</h3>
          <p class="text-gray-600">
            Geen handmatige invoer nodig. De kassa doet het werk, AutoLeaf toont het resultaat.
          </p>
        </div>
        <div class="feature-card">
          <div class="text-5xl mb-6">📊</div>
          <h3 class="text-xl font-bold mb-3 text-forest">Dashboard</h3>
          <p class="text-gray-600">
            Beheer alles vanuit één overzichtelijk dashboard. Prijzen, beschrijvingen, categorieën.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-forest py-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-6">Benieuwd naar alle mogelijkheden?</h2>
      <p class="text-xl text-white/80 mb-8">
        Plan een demo en we laten u precies zien hoe AutoLeaf werkt voor uw coffeeshop.
      </p>
      <a href={`${base}contact/`} class="btn-primary bg-white !text-forest hover:!bg-white/90">
        Demo aanvragen →
      </a>
    </div>
  </section>

</Layout>
