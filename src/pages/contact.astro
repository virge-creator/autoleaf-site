---
import Layout from '../layouts/Layout.astro';
const baseRaw = import.meta.env.BASE_URL;
const base = baseRaw.endsWith('/') ? baseRaw : baseRaw + '/';
---

<Layout title="Contact" description="Neem contact op met AutoLeaf Displays voor een demo of meer informatie over onze digitale menukaarten voor coffeeshops.">
  
  <!-- Hero -->
  <section class="hero py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">
          Neem <span class="text-leaf-light">contact</span> op
        </h1>
        <p class="text-xl text-white/80">
          Benieuwd wat AutoLeaf voor uw coffeeshop kan betekenen? We plannen graag een vrijblijvende demo.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16">
        
        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-bold mb-6">Stuur ons een bericht</h2>
          <form class="space-y-6" action="https://formspree.io/f/mkokrkdl" method="POST">
            <div class="grid sm:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Naam *</label>
                <input type="text" name="name" required
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-leaf focus:ring-2 focus:ring-leaf/20 outline-none transition-colors">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Coffeeshop naam</label>
                <input type="text" name="company"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-leaf focus:ring-2 focus:ring-leaf/20 outline-none transition-colors">
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">E-mail *</label>
              <input type="email" name="email" required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-leaf focus:ring-2 focus:ring-leaf/20 outline-none transition-colors">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Telefoon</label>
              <input type="tel" name="phone"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-leaf focus:ring-2 focus:ring-leaf/20 outline-none transition-colors">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Huidig kassasysteem</label>
              <select name="pos_system" 
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-leaf focus:ring-2 focus:ring-leaf/20 outline-none transition-colors">
                <option value="">Selecteer...</option>
                <option value="ebpos">EBPos</option>
                <option value="vectron">Vectron Commander</option>
                <option value="other">Anders</option>
                <option value="none">Nog geen kassasysteem</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Bericht *</label>
              <textarea name="message" rows="5" required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-leaf focus:ring-2 focus:ring-leaf/20 outline-none transition-colors resize-none"
                placeholder="Vertel ons over uw coffeeshop en waar u naar op zoek bent..."></textarea>
            </div>
            <button type="submit" class="btn-primary w-full sm:w-auto">
              Verstuur bericht →
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-bold mb-6">Of neem direct contact op</h2>
          
          <div class="space-y-8">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-leaf/10 rounded-lg flex items-center justify-center text-2xl flex-shrink-0">
                📧
              </div>
              <div>
                <h3 class="font-semibold mb-1">E-mail</h3>
                <a href="mailto:info@autoleaf.nl" class="text-leaf hover:underline">info@autoleaf.nl</a>
                <p class="text-gray-500 text-sm mt-1">We reageren binnen 24 uur</p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-leaf/10 rounded-lg flex items-center justify-center text-2xl flex-shrink-0">
                📞
              </div>
              <div>
                <h3 class="font-semibold mb-1">Telefoon</h3>
                <a href="tel:+31495794123" class="text-leaf hover:underline">+31 495 794 123</a>
                <p class="text-gray-500 text-sm mt-1">Ma-Vr 9:00 - 17:00</p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-leaf/10 rounded-lg flex items-center justify-center text-2xl flex-shrink-0">
                📍
              </div>
              <div>
                <h3 class="font-semibold mb-1">Locatie</h3>
                <p class="text-gray-600">Nederland</p>
                <p class="text-gray-500 text-sm mt-1">We komen graag langs voor een demo</p>
              </div>
            </div>
          </div>

          <!-- FAQ teaser -->
          <div class="mt-12 p-6 bg-cream rounded-xl">
            <h3 class="font-bold mb-3">Veelgestelde vragen</h3>
            <ul class="space-y-3 text-sm">
              <li>
                <strong class="text-forest">Wat kost AutoLeaf?</strong>
                <p class="text-gray-600 mt-1">Prijzen zijn afhankelijk van uw wensen. Vraag een offerte aan.</p>
              </li>
              <li>
                <strong class="text-forest">Hoe lang duurt de installatie?</strong>
                <p class="text-gray-600 mt-1">Gemiddeld 1-2 weken van intake tot live.</p>
              </li>
              <li>
                <strong class="text-forest">Moet ik nieuwe hardware kopen?</strong>
                <p class="text-gray-600 mt-1">AutoLeaf werkt op standaard tablets en smart-TVs.</p>
              </li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>
